{
  "name": "diceforge-launcher",
  "version": "1.0.0",
  "description": "Launcher officiel DiceForge — Minecraft 1.21.11",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-mac-intel": "electron-builder --mac --x64",
    "build-mac-arm": "electron-builder --mac --arm64"
  },
  "build": {
    "appId": "net.diceforge.launcher",
    "productName": "DiceForge Launcher",
    "copyright": "© 2026 DiceForge",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "minimumSystemVersion": "10.13.0",
      "category": "public.app-category.games"
    },
    "dmg": {
      "title": "DiceForge Launcher",
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "DiceForge Launcher",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerSidebar": "assets/installer-sidebar.bmp",
      "uninstallerSidebar": "assets/installer-sidebar.bmp"
    }
  },
  "dependencies": {
    "minecraft-launcher-core": "^3.6.2",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}